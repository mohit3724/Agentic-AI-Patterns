# =============================================
# Interview Preparation Coach — Environment Variables
# =============================================

# Get your free Gemini API key from:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSyAMfWol3k5Q5QW1Fg"

# Model to use (free tier options):
# gemini-1.5-flash  → Fast, free tier (recommended)
# gemini-1.5-flash-8b → Lightest model, most free
# gemini-2.0-flash-exp → Latest experimental
GEMINI_MODEL=gemini-3.5-flash

# Session & Memory Settings
MEMORY_FILE=./data/memory_store.json
SESSION_LOG_DIR=./data/sessions/

# Coach Configuration
MAX_QUESTIONS_PER_TOPIC=5
MOCK_QA_ROUNDS=3
